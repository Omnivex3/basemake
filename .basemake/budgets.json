{
  "version": 1,
  "rules": [
    {
      "type": "table",
      "table": "statuses",
      "max_seq_rows": 100,
      "message": "Statuses table must use index scans — this is our largest table"
    },
    {
      "type": "migration",
      "pattern": "V*__*.sql",
      "threshold": "5s",
      "message": "Migrations must complete in under 5s"
    }
  ]
}
