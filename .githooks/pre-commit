#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "  🔍 basemake pre-commit checks"
echo ""

# 1. Go vet
echo "  ${YELLOW}→${NC} Running go vet..."
if ! go vet ./...; then
    echo "  ${RED}✗ go vet failed${NC}"
    exit 1
fi
echo "  ${GREEN}✓ go vet passed${NC}"
echo ""

# 2. Formatting
echo "  ${YELLOW}→${NC} Checking formatting..."
UNFMT=$(gofmt -l .)
if [ -n "$UNFMT" ]; then
    echo "  ${RED}✗ Unformatted files:${NC}"
    echo "$UNFMT" | sed 's/^/    /'
    echo ""
    echo "  Run: make fmt"
    exit 1
fi
echo "  ${GREEN}✓ Formatting clean${NC}"
echo ""

# 3. Build (syntax check)
echo "  ${YELLOW}→${NC} Checking compilation..."
if ! go build -o /dev/null . 2>/dev/null; then
    echo "  ${RED}✗ Build failed${NC}"
    exit 1
fi
echo "  ${GREEN}✓ Compiles clean${NC}"
echo ""

# 4. Tests on changed packages (quick)
CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' | sed 's:/[^/]*$::' | sed 's/^/.\//' | sort -u | tr '\n' ' ') || true
if [ -n "$CHANGED" ]; then
    echo "  ${YELLOW}→${NC} Running tests on changed packages..."
    if ! go test -count=1 $CHANGED 2>&1; then
        echo "  ${RED}✗ Tests failed${NC}"
        exit 1
    fi
    echo "  ${GREEN}✓ Tests passed${NC}"
fi
echo ""

echo "  ${GREEN}✅ All checks passed${NC}"
exit 0
